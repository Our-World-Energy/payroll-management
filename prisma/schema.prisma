// Prisma schema — Our World Energy Contractor Suite

generator client {
  provider      = "prisma-client-js"
  // "native" for local; rhel-openssl-3.0.x for Netlify/AWS Lambda functions
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL") // pooled (pgbouncer / Supavisor — port 6543)
  directUrl = env("DIRECT_URL") // direct connection (port 5432) for migrations
}

// ── Enums ─────────────────────────────────────────────────────────────

enum Role {
  ADMIN
  MANAGER
  FIELD
}

enum SiteKind {
  SOLAR
  WIND
  HYDRO
  GEO
  STORAGE
}

enum TimeOffStatus {
  PENDING
  APPROVED
  REJECTED
}

enum PayrollStatus {
  DRAFT
  APPROVED
  PAID
}

enum ActivityKind {
  CONTRACTOR_CERTIFIED
  SITE_DEPLOYED
  PAYROLL_FINALIZED
  CERTIFICATION_EXPIRING
  SHIFT_STARTED
  TIME_OFF_REQUESTED
}

// ── Models ────────────────────────────────────────────────────────────

/// Mirror of Supabase auth.users — keyed by the auth user UUID.
model Profile {
  id        String   @id @db.Uuid // auth.users.id
  email     String   @unique
  fullName  String?
  avatarUrl String?
  role      Role     @default(FIELD)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  contractor Contractor?

  @@map("profiles")
}

model Site {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @unique
  kind      SiteKind
  region    String?
  active    Boolean  @default(true)
  capacity  Int? // headcount target
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  shifts      Shift[]
  contractors Contractor[]

  @@map("sites")
}

model Contractor {
  id              String    @id @default(uuid()) @db.Uuid
  profileId       String?   @unique @db.Uuid
  profile         Profile?  @relation(fields: [profileId], references: [id], onDelete: SetNull)
  firstName       String
  lastName        String
  email           String    @unique
  phone           String?
  hourlyRateCents Int       @default(0)
  certifiedLevel  Int       @default(0)
  certExpiresAt   DateTime?
  homeSiteId      String?   @db.Uuid
  homeSite        Site?     @relation(fields: [homeSiteId], references: [id], onDelete: SetNull)

  // ── Contract detail (shown in the attendance Action popup) ──────────
  department        String?
  location          String?
  shiftType         String?
  employmentStatus  String?                          // Active | Inactive | On Leave …
  offsetCredits     Decimal  @default(0) @db.Decimal(6, 2)
  ptoCredits        Decimal  @default(0) @db.Decimal(6, 2)
  sickLeaveCredits  Decimal  @default(0) @db.Decimal(6, 2)
  targetMinutes     Int      @default(2400)              // weekly target (Fixed & Flexible)
  timezone          String   @default("America/Phoenix") // IANA tz for In/Out display (per location)

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  shifts         Shift[]
  timeOff        TimeOff[]
  payrollEntries PayrollEntry[]

  @@index([homeSiteId])
  @@map("contractors")
}

model Shift {
  id           String     @id @default(uuid()) @db.Uuid
  contractorId String     @db.Uuid
  contractor   Contractor @relation(fields: [contractorId], references: [id], onDelete: Cascade)
  siteId       String     @db.Uuid
  site         Site       @relation(fields: [siteId], references: [id], onDelete: Cascade)
  startedAt    DateTime
  endedAt      DateTime?
  notes        String?
  createdAt    DateTime   @default(now())

  @@index([contractorId, startedAt])
  @@index([siteId, startedAt])
  @@map("shifts")
}

model TimeOff {
  id           String        @id @default(uuid()) @db.Uuid
  contractorId String        @db.Uuid
  contractor   Contractor    @relation(fields: [contractorId], references: [id], onDelete: Cascade)
  startDate    DateTime      @db.Date
  endDate      DateTime      @db.Date
  reason       String?
  status       TimeOffStatus @default(PENDING)
  decidedById  String?       @db.Uuid
  decidedAt    DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([contractorId, status])
  @@map("time_off_requests")
}

model PayrollRun {
  id          String        @id @default(uuid()) @db.Uuid
  periodStart DateTime      @db.Date
  periodEnd   DateTime      @db.Date
  status      PayrollStatus @default(DRAFT)
  totalCents  BigInt        @default(0)
  approvedAt  DateTime?
  paidAt      DateTime?
  createdAt   DateTime      @default(now())

  entries PayrollEntry[]

  @@unique([periodStart, periodEnd])
  @@map("payroll_runs")
}

model PayrollEntry {
  id           String     @id @default(uuid()) @db.Uuid
  runId        String     @db.Uuid
  run          PayrollRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  contractorId String     @db.Uuid
  contractor   Contractor @relation(fields: [contractorId], references: [id], onDelete: Cascade)
  hoursWorked  Decimal    @db.Decimal(10, 2)
  grossCents   BigInt
  notes        String?

  @@unique([runId, contractorId])
  @@map("payroll_entries")
}

model Activity {
  id           String       @id @default(uuid()) @db.Uuid
  kind         ActivityKind
  title        String
  detail       String?
  contractorId String?      @db.Uuid
  siteId       String?      @db.Uuid
  createdAt    DateTime     @default(now())

  @@index([createdAt])
  @@map("activity_log")
}

model ContractorProfile {
  id                String   @id @default(uuid()) @db.Uuid
  uid               String   @unique
  firstName         String   @default("")
  middleName        String   @default("")
  surname           String   @default("")
  fullName          String   @default("")
  avatar            String   @default("")
  dob               String   @default("")
  gender            String   @default("Not Specified")
  contractorId      String   @default("")
  department        String   @default("")
  subDepartment     String   @default("")
  role              String   @default("")
  location          String   @default("")
  status            String   @default("Active")
  hireDate          String   @default("")
  officeLocation    String   @default("")
  currency          String   @default("USD")
  monthlyRate       String   @default("")
  weeklyRate        String   @default("")
  hourlyRate        String   @default("")
  email             String   @default("")
  payCategory       String   @default("")
  shiftHours        String   @default("")
  restDay           String   @default("")
  manager           String   @default("")
  payPeriod         String   @default("Sunday – Saturday")
  shiftType         String   @default("Fixed")
  createdOn         String   @default("")
  dismissalDate     String   @default("")
  dismissalReason   String   @default("")
  equipmentProvided Boolean  @default(false)
  worksnapId        String   @default("")

  // Time-off tracking
  ptoBalance          Float    @default(0)
  ptoUsed             Float    @default(0)
  sickLeaveBalance    Float    @default(0)
  sickLeaveUsed       Float    @default(0)
  birthdayLeave        Float    @default(0)
  birthdayLeaveUsed    Float    @default(0) // cumulative amount repaid so far from newly-accrued PTO
  advanceSickLeave     Float    @default(0)
  advanceSickLeaveUsed Float    @default(0) // cumulative amount repaid so far from newly-accrued Sick Leave
  specialLeaveCredits  Float    @default(0) // admin-granted bonus leave balance, drawable via Leave Override
  specialLeaveUsed     Float    @default(0)

  @@map("contractor_profiles")
}

// ── Worksnaps sync + attendance (tables already exist via migrations) ───

enum TimeOffKind {
  HO_HOLIDAY
  PTO
  SICK_LEAVE
  SICK_LEAVE_HALF_DAY
  PTO_HALF_DAY
  UNPAID_LEAVE
  OPEN
  NOT_SET
}

enum AttendanceRequestStatus {
  APPROVED
  REJECTED
  OPEN
  NOT_SET
}

/// Worksnap time-tracking detail — one row per user × project × task × date × type.
model WorksnapEntry {
  id             String   @id @default(uuid()) @db.Uuid
  worksnapUserId Int
  email          String   @default("")
  userName       String
  projectId      Int
  projectName    String
  taskId         Int      @default(0)
  taskName       String   @default("")
  category       String   @default("Work")
  type           String
  entryDate      DateTime @db.Date
  durationMins   Int
  syncedAt       DateTime @default(now())

  @@unique([worksnapUserId, projectId, taskId, entryDate, type], name: "worksnap_natural_key")
  @@index([entryDate])
  @@index([worksnapUserId, entryDate])
  @@index([projectId, entryDate])
  @@index([email, entryDate])
  @@map("worksnap_entries")
}

/// Per-user per-task per-week rollup, derived from worksnap_entries.
model WorksnapWeeklyTask {
  id             String   @id @default(uuid()) @db.Uuid
  worksnapUserId Int
  email          String   @default("")
  userName       String
  weekStart      DateTime @db.Date
  projectId      Int
  projectName    String
  taskId         Int      @default(0)
  taskName       String   @default("")
  category       String   @default("Work")
  totalMins      Int      @default(0)
  daysLogged     Int      @default(0)
  syncedAt       DateTime @default(now())

  @@unique([worksnapUserId, weekStart, projectId, taskId], name: "worksnap_weekly_task_key")
  @@index([weekStart])
  @@index([email, weekStart])
  @@map("worksnap_weekly_task")
}

/// Per-user per-day first clock-in / last clock-out, derived from Worksnaps time entries.
model WorksnapDailyLog {
  id             String   @id @default(uuid()) @db.Uuid
  worksnapUserId Int
  email          String   @default("")
  userName       String
  entryDate      DateTime @db.Date
  firstIn        DateTime @db.Timestamptz(3)
  lastOut        DateTime @db.Timestamptz(3)
  totalMins      Int      @default(0)
  entries        Int      @default(0)
  syncedAt       DateTime @default(now())

  @@unique([worksnapUserId, entryDate], name: "worksnap_daily_log_key")
  @@index([entryDate])
  @@index([email, entryDate])
  @@map("worksnap_daily_log")
}

/// Per-employee per-week attendance workflow status (request status set by admin).
model AttendanceWeekStatus {
  id                   String                  @id @default(uuid()) @db.Uuid
  worksnapUserId       Int
  email                String                  @default("")
  weekStart            DateTime                @db.Date
  timeOffStatus        TimeOffKind             @default(NOT_SET)
  requestStatus        AttendanceRequestStatus @default(NOT_SET)
  manualAdjustmentTime Int                     @default(0)
  completionMinutes    Int?
  totalLocalHolidayMinutes Int?                                    // sum of the week's per-day "Local HO Time"
  totalEvaluatedRegularMinutes Int      @default(0)                // sum of the week's per-day "Evaluated Regular Time"
  totalEvaluatedMinutes Int             @default(0)                // sum of the week's per-day "Evaluated Time"
  totalUsHoMinutes     Int                     @default(0)         // sum of the week's per-day "US HO Time"
  totalRegularOtMinutes Int                    @default(0)         // sum of the week's per-day "Regular OT Time"
  totalRdOtMinutes     Int                     @default(0)         // sum of the week's per-day "RD OT Time"
  totalHoOtMinutes     Int                     @default(0)         // sum of the week's per-day "HO OT Time"
  note                 String?
  updatedAt            DateTime                @updatedAt @default(now())

  @@unique([worksnapUserId, weekStart], name: "attendance_week_key")
  @@index([weekStart])
  @@index([email, weekStart])
  @@map("attendance_week_status")
}

model Holiday {
  id          String    @id @default(uuid()) @db.Uuid
  name        String
  country     String
  date        DateTime
  timeZone    String? // IANA zone for `country` (e.g. "Asia/Manila")
  arizonaDate DateTime? // Arizona local date+time for midnight of `date` in `timeZone`
  createdAt   DateTime  @default(now())

  @@map("holidays")
}

/// Offshore Announcements board shown on the Dashboard — admin-posted, each
/// scoped to a specific location (or all locations).
model Announcement {
  id        String   @id @default(uuid()) @db.Uuid
  title     String
  body      String
  location  String
  date      DateTime @db.Date // the date this announcement is posted for
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("announcements")
}

/// Time-off requests submitted through the contractor portal
model ContractorLeaveRequest {
  id                 String   @id @default(uuid()) @db.Uuid
  email              String
  type               String   // "PTO" | "PTO Half Day" | "Sick Leave" | "Sick Leave Half Day"
  startDate          String
  endDate            String
  durationDays       Int
  reason             String   @default("")
  status             String   @default("Pending") // "Pending" | "Approved" | "Rejected"
  ptoUsedHours       Float    @default(0) // hours this request deducts from PTO Used if approved
  sickLeaveUsedHours Float    @default(0) // hours this request deducts from Sick Leave Used if approved
  specialLeaveUsedHours Float @default(0) // hours this request deducts from Special Leave Used if approved
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([email, createdAt])
  @@map("contractor_leave_requests")
}

/// Manual per-employee per-WEEK payroll adjustments entered by an admin from
/// the Payroll Voucher's "Review" action — these have no other data source
/// anywhere in the system. Earnings: Bonus, MISC, Retro Pay, Reimbursement.
/// Deductions: Cash Advance, HMO Premium, Tax.
model PayrollAdjustment {
  id          String   @id @default(uuid()) @db.Uuid
  email       String
  weekStart   String   // "YYYY-MM-DD" (Sunday) — same week-key convention used across Attendance/Payroll
  bonus       Float    @default(0)
  misc        Float    @default(0)
  retroPay    Float    @default(0)
  reim        Float    @default(0)
  cashAdvance Float    @default(0)
  hmo         Float    @default(0)
  tax         Float    @default(0)
  updatedAt   DateTime @updatedAt

  @@unique([email, weekStart], name: "payroll_adjustment_key")
  @@map("payroll_adjustments")
}

/// Org-wide settings: office locations list
model OrgOfficeLocation {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @unique
  createdAt DateTime @default(now())

  @@map("org_office_locations")
}

/// Org-wide settings: manager names list
model OrgManager {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @unique
  createdAt DateTime @default(now())

  @@map("org_managers")
}

/// Org-wide settings: department names
model OrgDepartment {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @unique
  createdAt DateTime @default(now())

  subDepartments OrgSubDepartment[]

  @@map("org_departments")
}

/// Org-wide settings: sub-departments linked to a department
model OrgSubDepartment {
  id           String        @id @default(uuid()) @db.Uuid
  departmentId String        @db.Uuid
  department   OrgDepartment @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  name         String
  createdAt    DateTime      @default(now())

  roles OrgRole[]

  @@unique([departmentId, name])
  @@map("org_sub_departments")
}

/// Org-wide settings: roles linked to a sub-department
model OrgRole {
  id              String           @id @default(uuid()) @db.Uuid
  subDepartmentId String           @db.Uuid
  subDepartment   OrgSubDepartment @relation(fields: [subDepartmentId], references: [id], onDelete: Cascade)
  name            String
  createdAt       DateTime         @default(now())

  @@unique([subDepartmentId, name])
  @@map("org_roles")
}

/// Per-employee per-DAY attendance review snapshot (admin picks the date) —
/// mirrors every column of the Attendance Review modal's daily table so a
/// reopened review always matches exactly what was last saved.
model AttendanceDayStatus {
  id                   String                  @id @default(uuid()) @db.Uuid
  worksnapUserId       Int
  email                String                  @default("")
  date                 DateTime                @db.Date
  decisionStatus       AttendanceRequestStatus @default(NOT_SET) // "Approval Status"
  evaluatedMinutes     Int                     @default(0)       // "Evaluated Time"
  adjustedMinutes      Int?                                       // "Adjusted Time" (null = no manual override)
  holidayMinutes       Int                     @default(0)       // "US HO Time"
  localHoliday         String?                                    // "Local HO" (holiday name for the contractor's own country)
  localHolidayMinutes  Int?                                       // "Local HO Time"
  evaluatedRegularMinutes Int                  @default(0)       // "Evaluated Regular Time"
  regularOtMinutes     Int                     @default(0)       // "Regular OT Time"
  rdOtMinutes          Int                     @default(0)       // "RD OT Time"
  hoOtMinutes          Int                     @default(0)       // "HO OT Time"
  timeOffStatus        TimeOffKind             @default(NOT_SET) // "Time Off Status"
  timeOffMinutes       Int                     @default(0)       // "Time Off Time"
  manualAdjustmentTime Int                     @default(0)
  note                 String?
  updatedAt            DateTime                @updatedAt @default(now())

  @@unique([worksnapUserId, date], name: "attendance_day_key")
  @@index([date])
  @@index([email, date])
  @@map("attendance_day_status")
}
